<?xml version="1.0" encoding="utf-8"?>
<!--
  Vibely POS — Android Adaptive Icon Background
  A clean off-white fill matching the app's background color (#F8FAFC).
  The subtle color separates it from pure white home screen backgrounds
  while keeping the icon feeling light and modern.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Solid off-white background fill -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#F8FAFC" />

</vector>
