# Supabase Configuration
# Get these values from your Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Configuration
# Generate a secure random string for production
JWT_SECRET=your-jwt-secret-here

# Database Configuration (Optional - for direct PostgreSQL connection)
DB_HOST=db.your-project-id.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# Server Configuration
PORT=8080
HOST=0.0.0.0

# API Base URL Configuration
# Base URL for the backend API (used by mobile/desktop clients)
# Default: http://localhost:8080 (if not set)
API_BASE_URL=http://localhost:8080

# Security Configuration
# HTTPS enforcement - set to true in production to redirect HTTP to HTTPS
ENFORCE_HTTPS=false

# Debug Mode (Optional - bypasses authentication for development)
# ⚠️ WARNING: NEVER enable in production!
DEBUG_MODE=false
